{
    "name": "Rust ESP32",
    "image": "espressif/idf-rust:all_latest",
    "customizations": {
        "vscode": {
            "extensions": ["rust-lang.rust-analyzer"]
        }
    },
    "runArgs": ["--privileged", "--device=/dev/ttyUSB0"],
    "postCreateCommand": "command -v cargo-generate >/dev/null 2>&1 || cargo install cargo-generate"
}